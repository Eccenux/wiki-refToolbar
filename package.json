{
	"name": "wiki-ref-toolbar",
	"type": "commonjs",
	"scripts": {
		"off--test": "mocha",
		"off--build-less": "lessc src/less/main.less dist/refToolbar.css",
		"off--build-js": "browserify src/main.js -o dist/refToolbar.js",
		"off--build": "npm run build-less && npm run build-js && node -e \"console.log('Build done');\" ",
		"test": "vitest",
		"test:run": "vitest run",
		"build": "node -e \"console.log('Build NOP');\" ",
		"deploy-dev": "node wikiploy-dev.mjs",
		"deploy": "node wikiploy.mjs",
		"rollout-dev": "npm run build && npm run deploy-dev",
		"rollout": "npm run build && npm run deploy"
	},
	"devDependencies": {
		"eslint": "8.x",
		"vitest": "^4.1.0",
		"wikiploy": "2.x"
	}
}
